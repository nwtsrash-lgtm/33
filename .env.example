# ═══════════════════════════════════════════════════════════════════════
#  mahwous-smart-pricing-v30 — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════

# ─── AI Keys (at least one required) ────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# GEMINI_API_KEYS=["key1","key2","key3"]   # optional: multiple keys for rotation
# OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
# COHERE_API_KEY=YOUR_COHERE_KEY

# ─── Google Cloud Platform — Core ───────────────────────────────────────────
# Required to enable any GCP backend
GCP_PROJECT_ID=sanguine-orb-493713-q6

# ─── GCS: SQLite Backup Sync (recommended first step) ───────────────────────
# Create a GCS bucket and set GCS_BUCKET_NAME to enable automatic
# SQLite → Cloud Storage sync every 5 minutes.
# Authentication: run  gcloud auth application-default login
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_DB_BLOB_NAME=vision2030/pricing_v30.db   # path inside the bucket
GCS_SYNC_COOLDOWN=60                         # minimum seconds between uploads

# ─── Cloud SQL: PostgreSQL (optional full cloud backend) ────────────────────
# Format: PROJECT_ID:REGION:INSTANCE_NAME  (from GCP console → Cloud SQL)
# CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:vision2030-db
# DB_USER=vision2030_user
# DB_PASS=your-secure-password
# DB_NAME=vision2030

# ─── Firestore (optional document-store backend) ────────────────────────────
# USE_FIRESTORE=true   # set to true + GCP_PROJECT_ID to enable Firestore writes

# ─── Local storage override ─────────────────────────────────────────────────
# Absolute path for the data/ directory.
# Leave unset to use the default ./data/ folder in the project root.
# DATA_DIR=/app/data

# ─── Make.com Webhooks ───────────────────────────────────────────────────────
# WEBHOOK_UPDATE_PRICES=https://hook.eu2.make.com/...
# WEBHOOK_NEW_PRODUCTS=https://hook.eu2.make.com/...
